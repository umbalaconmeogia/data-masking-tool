# Database connection
# DB_DRIVER: mysql | pgsql | sqlite (sqlite is intended for testing/demo only)
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# For sqlite, DB_NAME is the database file path and the other DB_* keys are ignored.
DB_NAME=my_database
DB_USER=root
DB_PASSWORD=secret
# MySQL only
DB_CHARSET=utf8mb4

# Masking options (all optional)
# Persona locale used for tables that have no name-type rule (email/tel only tables)
MASK_DEFAULT_LOCALE=japanese
# Rows fetched/updated per batch
MASK_BATCH_SIZE=500
# Path to the data-sample directory (default: ../data-sample relative to script-python)
#MASK_DATA_DIR=./data-sample
# Set for reproducible masking output
#MASK_SEED=42
